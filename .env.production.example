# StormAPI Production Environment Variables Example
# Copy this file to .env on the production host server

# Database Configuration
DB_HOST=db
DB_NAME=stormapi
DB_USER=stormapi
DB_PASSWORD=change_this_to_a_secure_database_password

# Spring Configuration
SPRING_PROFILES_ACTIVE=prod

# Security & Authentication
JWT_SECRET=change_this_to_a_secure_256_bit_random_secret_key_in_production
GOOGLE_CLIENT_ID=your_production_google_client_id
GOOGLE_CLIENT_SECRET=your_production_google_client_secret
GITHUB_CLIENT_ID=your_production_github_client_id
GITHUB_CLIENT_SECRET=your_production_github_client_secret

# CORS & Frontend URLs
FRONTEND_URL=https://stormapi.dev
ALLOWED_ORIGINS=https://stormapi.dev,https://api.stormapi.dev
